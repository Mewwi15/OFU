{
  "expo": {
    "name": "OFU",
    "slug": "my-rn-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myrnapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.my-rn-app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F15929",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.anonymous.myrnapp",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#F15929"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-maps",
        {
          "requestLocationPermission": true,
          "locationPermission": "ให้ อู้ฟู่ เข้าถึงตำแหน่งของคุณ เพื่อปักหมุดที่อยู่จัดส่ง"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "ให้ อู้ฟู่ ใช้ตำแหน่งของคุณ เพื่อปักหมุดที่อยู่จัดส่ง"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ให้ อู้ฟู่ เข้าถึงรูปภาพ เพื่อแนบสลิปการโอนเงิน"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "ให้ อู้ฟู่ ใช้ Face ID เพื่อปลดล็อกแอป"
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "ให้ อู้ฟู่ ใช้ Face ID เพื่อปลดล็อกแอป"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5a1851e6-07e3-4ea9-b972-23ac0cb21056"
      }
    },
    "owner": "mewwi"
  }
}
