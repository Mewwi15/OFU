# Google Maps API key — Android only (iOS uses Apple Maps, no key needed).
#
# Setup:
#   1. Google Cloud Console → create a project (or reuse one).
#   2. Enable "Maps SDK for Android".
#   3. Create an API key (restrict it to Android apps + your package name
#      com.anonymous.my-rn-app for safety).
#   4. Copy this file to .env.local and paste the key below.
#
#   cp .env.example .env.local
#
GOOGLE_MAPS_API_KEY=

# Supabase — points the app at a backend. For local dev, run `npx supabase start`
# and use its API URL + anon key (the anon key is public by design; RLS gates it).
# Cloud values come from the Supabase project dashboard. EXPO_PUBLIC_* are inlined
# into the client bundle, so only ever put public values here.
#   Local default URL: http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
